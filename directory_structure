└── restora_mobile/              # Flutter Frontend Mobile application
    ├── pubspec.yaml             # Flutter dependencies (audio, svg packages)
    ├── assets/
    │   └── images/              # Human silhouette SVG/images for body map
    ├── android/
    ├── ios/
    └── lib/                     # Flutter Source Code
        ├── main.dart            # Application entry point
        ├── core/                # Global constants, themes, network clients
